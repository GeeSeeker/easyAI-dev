{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://easyai.dev/schemas/spec-schema.json",
  "title": "easyAI Spec File Schema",
  "description": "定义 .trellis/spec/ 下规范文件 YAML frontmatter 的格式约束。",
  "type": "object",
  "required": ["title", "version", "category"],
  "properties": {
    "title": {
      "type": "string",
      "description": "规范标题"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "规范版本号（SemVer 格式）"
    },
    "category": {
      "type": "string",
      "enum": ["frontend", "backend", "guides", "general"],
      "description": "规范分类"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"],
      "default": "draft",
      "description": "规范状态"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date",
      "description": "最近更新日期"
    },
    "owner": {
      "type": "string",
      "description": "规范维护者"
    },
    "content": {
      "type": "string",
      "description": "规范正文（Markdown 格式）"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "标签列表，用于 context_generate 关键词匹配"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "规范间依赖关系（引用其他 spec 的路径）"
    },
    "minTokenEstimate": {
      "type": "integer",
      "minimum": 0,
      "description": "最小 Token 估算值（辅助上下文预算管理）"
    },
    "maxTokenEstimate": {
      "type": "integer",
      "minimum": 0,
      "description": "最大 Token 估算值（辅助上下文预算管理）"
    }
  },
  "additionalProperties": false
}
